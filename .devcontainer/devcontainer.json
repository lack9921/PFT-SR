{
    "name": "PFT-SR (CVPR 2025)",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "runArgs": [
        "--gpus", "all",
        "--shm-size", "8gb"
    ],
    "mounts": [
        "source=D:\\dataset,target=/datasets_host,type=bind"
    ],
    "customizations": {
        "vscode": {
            "extensions": ["ms-python.python"]
        }
    },
    "workspaceFolder": "/workspace"
}
