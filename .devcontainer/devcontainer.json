{
    "name": "PFT-SR (CVPR 2025)",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "runArgs": [
        "--gpus", "all",
        "--shm-size", "8gb"
    ],
    "mounts": [
        "source=F:\\Lovif\\LoViF 2026,target=/datasets/LoViF_2026,type=bind",
        "source=F:\\Lovif\\LoViF_val,target=/datasets/LoViF_val,type=bind"
    ],
    "customizations": {
        "vscode": {
            "extensions": ["ms-python.python"]
        }
    },
    "workspaceFolder": "/workspace"
}
