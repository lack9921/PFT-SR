{
    "name": "PFT-SR-Blackwell-Environment",
    "image": "pft-test:latest",
    "runArgs": [
        "--gpus", "all",
        "--shm-size", "16gb",
        "--env", "PYTHONPATH=/workspace/ops_smm"
    ],
    "mounts": [
        "source=E:\\Project\\PFT-SR,target=/workspace,type=bind,consistency=cached",
        "source=D:\\02_Datasets,target=/datasets_host,type=bind,consistency=cached"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance"
            ],
            "settings": {
                "python.analysis.extraPaths": [
                    "/workspace/ops_smm"
                ]
            }
        }
    },
    "workspaceFolder": "/workspace",
    "remoteUser": "root",
    "shutdownAction": "none",
    "postCreateCommand": "cd /workspace/ops_smm && TORCH_CUDA_ARCH_LIST='8.0;8.6;8.9;9.0;12.0' python3 setup.py build_ext --inplace && echo 'SMM CUDA kernel compiled OK'"
}

