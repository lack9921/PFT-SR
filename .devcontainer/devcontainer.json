{
    "name": "PFT-SR-Blackwell-Environment",
    "build": {
        "context": ".",
        "dockerfile": "Dockerfile"
    },
    "runArgs": [
        "--gpus", "all",
        "--shm-size", "16gb",
        "--env", "PYTHONPATH=/workspace/ops_smm"
    ],
    "mounts": [
        "source=D:\\02_Datasets,target=/datasets_host,type=bind,consistency=cached"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance"
            ],
            "settings": {
                "python.analysis.extraPaths": [
                    "/workspace/ops_smm"
                ]
            }
        }
    },
    "workspaceFolder": "/workspace",
    "remoteUser": "root",
    "shutdownAction": "none",
    "postCreateCommand": "echo 'Compiling SMM CUDA kernel...' && /usr/local/bin/compile_smm.sh"
}

